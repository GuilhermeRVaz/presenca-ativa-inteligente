# --- BANCO DE DADOS LOCAL (DOCKER) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=busca_ativa_local
DATABASE_URL=postgresql://postgres:postgres@db:5432/busca_ativa_local

# --- CONFIGURAÇÕES DO APP ---
APP_NAME=busca-ativa-v2
DEBUG=true
LOG_LEVEL=INFO
SCHOOL_NAME=Escola
DEFAULT_SCHOOL_ID=

# --- SUPABASE (PRODUÇÃO) ---
# Obtenha em: Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- EVOLUTION API ---
EVOLUTION_API_URL=https://api.suainstancia.com
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_API_INSTANCE=sua_instancia
EVOLUTION_TIMEOUT_SECONDS=30

# --- TRIAGEM N8N ---
# Se rodando via Docker, use o nome do serviço 'api' se necessário, 
# mas geralmente o n8n chama a URL externa ou interna.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/triagem

# --- IA ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
